#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def abort_with(msg)
  warn msg
  exit 1
end

FileUtils.chdir APP_ROOT do
  puts "== Checking prerequisites =="
  unless system("which pg_isready > /dev/null 2>&1")
    abort_with <<~MSG
      ERROR: PostgreSQL is required but `pg_isready` is not on your PATH.
      Install PostgreSQL 16+ and ensure it's running:
        macOS:  brew install postgresql@16 && brew services start postgresql@16
        Linux:  use your distro's package manager (apt: postgresql-16, dnf: postgresql-server)
    MSG
  end

  unless system("pg_isready > /dev/null 2>&1")
    abort_with <<~MSG
      ERROR: PostgreSQL is installed but not accepting connections.
      Start it with:
        macOS:  brew services start postgresql@16
        Linux:  sudo systemctl start postgresql
    MSG
  end

  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  puts "\n== Clobbering compiled assets =="
  system! "bin/rails assets:clobber"

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Setup complete =="
    puts "Start the dev server with:  bin/dev"
    puts "Run the test suite with:    bin/rails test"
  end
end
